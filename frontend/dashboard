<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FitConnect — Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <nav class="bg-white shadow px-6 py-4 flex justify-between items-center">
    <h1 class="text-xl font-bold text-blue-600">FitConnect</h1>
    <div class="flex gap-4 items-center">
      <a href="dashboard.html"   class="text-sm font-medium text-blue-600">Dashboard</a>
      <a href="application.html" class="text-sm text-gray-500 hover:text-blue-600">Apply</a>
      <a href="status.html"      class="text-sm text-gray-500 hover:text-blue-600">My Status</a>
      <button onclick="logout()" class="text-sm text-gray-500 hover:text-red-500">Logout</button>
    </div>
  </nav>

  <div class="max-w-2xl mx-auto p-6">

    <!-- Welcome banner -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <p class="text-xs font-semibold text-gray-400 uppercase mb-1">Welcome back</p>
      <h2 class="text-2xl font-bold text-gray-800" id="welcome-name">Member</h2>
      <p class="text-sm text-gray-400 mt-1" id="welcome-email"></p>
    </div>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <p class="text-xs font-semibold text-gray-400 uppercase mb-4">Your Membership Application</p>

      <div id="app-loading" class="text-center text-gray-400 py-4">Loading…</div>

      <div id="app-status-block" class="hidden">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm text-gray-600">Status</span>
          <span id="dash-status-badge"></span>
        </div>
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm text-gray-600">Membership Plan</span>
          <span id="dash-plan" class="text-sm font-medium text-gray-800">—</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Submitted</span>
          <span id="dash-date" class="text-sm text-gray-500">—</span>
        </div>
        <div id="dash-rejection-wrap" class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded text-sm text-red-700">
          <strong>Rejection reason:</strong> <span id="dash-rejection"></span>
        </div>
      </div>

      <div id="no-app-block" class="hidden text-center py-4">
        <p class="text-gray-500 mb-3">You haven't applied for membership yet.</p>
        <a href="application.html"
          class="inline-block bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 font-medium text-sm">
          Apply Now →
        </a>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-xs font-semibold text-gray-400 uppercase mb-4">Quick Actions</p>
      <div class="grid grid-cols-2 gap-3">
        <a href="application.html"
          class="flex items-center gap-2 border rounded p-3 hover:border-blue-400 hover:bg-blue-50 transition-colors text-sm font-medium text-gray-700">
          📝 Apply for Membership
        </a>
        <a href="status.html"
          class="flex items-center gap-2 border rounded p-3 hover:border-blue-400 hover:bg-blue-50 transition-colors text-sm font-medium text-gray-700">
          🔍 Track Application
        </a>
      </div>
    </div>

  </div>

  <script>
    const API   = 'http://127.0.0.1:8000/api/users';
    const token = localStorage.getItem('access_token');

    if (!token) window.location.href = 'login.html';

    const u = JSON.parse(localStorage.getItem('user') || '{}');
    document.getElementById('welcome-name').textContent  = u.first_name ? `${u.first_name} ${u.last_name}` : 'Member';
    document.getElementById('welcome-email').textContent = u.email || '';

    const statusConfig = {
      pending:  { color: 'bg-yellow-100 text-yellow-700', label: '⏳ Pending' },
      approved: { color: 'bg-green-100 text-green-700',   label: '✅ Approved' },
      rejected: { color: 'bg-red-100 text-red-700',       label: '❌ Rejected' },
    };

    function fmt(dateStr) {
      if (!dateStr) return '—';
      return new Date(dateStr).toLocaleDateString('en-PH', { year:'numeric', month:'short', day:'numeric' });
    }

    async function loadStatus() {
      try {
        const res = await fetch(`${API}/application/status/`, {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        document.getElementById('app-loading').classList.add('hidden');

        if (res.status === 404) {
          document.getElementById('no-app-block').classList.remove('hidden');
          return;
        }

        if (!res.ok) throw new Error();
        const data = await res.json();

        document.getElementById('app-status-block').classList.remove('hidden');

        const cfg = statusConfig[data.status] || { color:'bg-gray-100 text-gray-700', label: data.status };
        document.getElementById('dash-status-badge').innerHTML =
          `<span class="inline-block ${cfg.color} px-3 py-1 rounded-full text-xs font-semibold">${cfg.label}</span>`;

        document.getElementById('dash-plan').textContent = data.plan_name || '—';
        document.getElementById('dash-date').textContent = fmt(data.submitted_at);

        if (data.rejection_reason) {
          document.getElementById('dash-rejection-wrap').classList.remove('hidden');
          document.getElementById('dash-rejection').textContent = data.rejection_reason;
        }
      } catch {
        document.getElementById('app-loading').textContent = 'Could not load application status.';
      }
    }

    function logout() {
      localStorage.clear();
      window.location.href = 'login.html';
    }

    loadStatus();
  </script>
</body>
</html>
